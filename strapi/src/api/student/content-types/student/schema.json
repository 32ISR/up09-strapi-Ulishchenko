{
  "kind": "collectionType",
  "collectionName": "students",
  "info": {
    "singularName": "student",
    "pluralName": "students",
    "displayName": "Student"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "enrollment": {
      "type": "date"
    },
    "enrollmentStatus": {
      "type": "enumeration",
      "enum": [
        "graduated",
        "current"
      ]
    }
  }
}
